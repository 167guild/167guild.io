# Production environment template
# Copy to .env.production and replace placeholders.
# Do not commit real credentials.

APP_ENV=production
PROJECT_NAME=167guild-wiki

DOMAIN=167guild.io
EMAIL=admin@example.com

WIKI_BASE_URL=https://167guild.io
WIKI_UPSTREAM=wikijs:3000

POSTGRES_DB=wikidb
POSTGRES_USER=wikijs
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

DB_HOST=postgres
DB_PORT=5432

GOOGLE_OAUTH_CLIENT_ID=replace-with-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_OAUTH_CALLBACK_URL=https://167guild.io/login/callback
