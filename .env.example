# Local development environment template
# Use placeholder values only. Do not commit real credentials.

APP_ENV=development
PROJECT_NAME=167guild-wiki

# Local wiki URL
WIKI_BASE_URL=http://localhost:3000
WIKI_UPSTREAM=wikijs:3000

# Reverse proxy placeholders
DOMAIN=example.com
EMAIL=admin@example.com

# Database placeholders
POSTGRES_DB=wikidb
POSTGRES_USER=wikijs
POSTGRES_PASSWORD=CHANGEME

# OAuth placeholders
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
