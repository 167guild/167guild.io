# Local development environment template
# Production uses deploy/examples/.env.production.example.
# Use placeholder values only. Do not commit real credentials.

APP_ENV=development
PROJECT_NAME=167guild-wiki

# Local wiki URL
WIKI_BASE_URL=http://localhost:3000
WIKI_UPSTREAM=wikijs:3000

# Reverse proxy placeholders for local config validation only.
# Production domain values live in deploy/examples/.env.production.example.
DOMAIN=example.com
EMAIL=admin@example.com

# PostgreSQL — persistent database for Wiki.js
# POSTGRES_DB: name of the database created on first startup
# POSTGRES_USER: database superuser created on first startup
# POSTGRES_PASSWORD: required; never commit real credentials
# The database is accessible only on the internal Docker network.
# Do not expose PostgreSQL ports publicly.
POSTGRES_DB=wikidb
POSTGRES_USER=wikijs
POSTGRES_PASSWORD=CHANGEME

# Wiki.js database connection — references PostgreSQL service above
# DB_HOST: Docker service name of the PostgreSQL container
# DB_PORT: PostgreSQL port (default: 5432)
DB_HOST=postgres
DB_PORT=5432

# OAuth placeholders
# Production callback URLs should use the HTTPS public domain.
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3000/login/callback

GUILD_REPO=git@github.com:167guild/167guild.io.git
